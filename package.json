{
  "name": "term-project",
  "version": "1.0.0",
  "description": "CSC 667 Term Project - Spring 2026",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:client": "node esbuild.config.mjs",
    "start": "node dist/index.js",
    "dev": "concurrently \"NODE_ENV=development tsx watch src/index.ts\" \"node esbuild.config.mjs --watch\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist/",
    "migrate": "tsx src/db/migrate.ts",
    "test": "node --import=tsx/esm --test src/sse.test.ts",
    "prepare": "husky || true",
    "build:server": "tsc"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-livereload": "^0.6.3",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/livereload": "^0.9.5",
    "@types/node": "^20.11.0",
    "@types/pg-promise": "^0.0.28",
    "concurrently": "^9.2.1",
    "connect-livereload": "^0.6.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "livereload": "^0.10.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pg-promise": "^12.6.1"
  }
}
