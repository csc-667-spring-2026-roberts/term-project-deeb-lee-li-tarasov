<%- include("partials/header", { title, currentUser }) %>
<div class="card stack">
  <div>
    <h1>Log in</h1>
    <p class="muted">Use your account to access the protected lobby page.</p>
  </div>

  <% if (error) { %>
  <div class="error"><%= error %></div>
  <% } %>

  <form class="stack" action="/auth/login" method="POST">
    <div class="form-group">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" value="<%= formData.email %>" required />
    </div>

    <div class="form-group">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required />
    </div>

    <button type="submit">Log in</button>
  </form>

  <p class="muted">Need an account? <a href="/register">Register</a></p>
</div>
<%- include("partials/footer") %>
