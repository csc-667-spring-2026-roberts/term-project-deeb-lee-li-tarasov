<%- include("partials/header", { title, currentUser: user }) %>

<div class="card stack wide">
  <div>
    <h1>The Lobby</h1>
    <p class="muted">Waiting for players to gather before the game begins.</p>
  </div>

  <div class="user-grid">
    <img class="avatar" src="<%= gravatarUrl %>" alt="Avatar" />
    <div class="stack">
      <div><strong><%= user.username %></strong></div>
      <div class="muted"><%= user.email %></div>
      <div class="muted">Joined <%= new Date(user.created_at).toLocaleDateString() %></div>
    </div>
  </div>

  <div>
    <h2>Live Connection</h2>
    <p class="status-line">Status: <span id="sse-status">connecting...</span></p>
    <ul id="sse-events"></ul>
  </div>

  <div>
    <h2>Players in Lobby</h2>
    <button id="load-users">Refresh</button>
    <ul id="user-list"></ul>
  </div>

  <div>
    <form class="inline-form" action="/auth/logout" method="POST">
      <button type="submit">Leave Mansion</button>
    </form>
  </div>
</div>

<template id="user-row">
  <li><span data-username></span></li>
</template>

<script defer src="/js/lobby.js" type="module"></script>

<%- include("partials/footer") %>
