<%- include("partials/header", { title, currentUser }) %>
<div class="card stack">
  <div>
    <h1>Create an account</h1>
    <p class="muted">Register here, then you will be redirected to the lobby.</p>
  </div>

  <% if (error) { %>
  <div class="error"><%= error %></div>
  <% } %>

  <form class="stack" action="/auth/register" method="POST">
    <div class="form-group">
      <label for="username">Username</label>
      <input id="username" name="username" type="text" value="<%= formData.username %>" required />
    </div>

    <div class="form-group">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" value="<%= formData.email %>" required />
    </div>

    <div class="form-group">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required />
    </div>

    <button type="submit">Register</button>
  </form>

  <p class="muted">Already have an account? <a href="/login">Log in</a></p>
</div>
<%- include("partials/footer") %>
