<%- include("partials/header", { title, currentUser }) %>

<div class="card stack">
  <h1>Database Test</h1>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Username</th>
        <th>Email</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% for (const record of records) { %>
      <tr>
        <td><%= record.id %></td>
        <td><%= record.username %></td>
        <td><%= record.email %></td>
        <td><%= new Date(record.created_at).toLocaleString() %></td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include("partials/footer") %>
